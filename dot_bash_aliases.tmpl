#!/bin/bash

# Detect display server (default to wayland)
if [ "$XDG_SESSION_TYPE" = "x11" ]; then
    export DISPLAY_SERVER="x11"
elif [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    export DISPLAY_SERVER="wayland"
else
    export DISPLAY_SERVER="wayland"
fi

alias steam-wine='WINEPREFIX=~/.steam_wine WINEDEBUG=-all wine ~/.steam_wine/drive_c/Program\ Files\ \(x86\)/Steam/Steam.exe >/dev/null 2>&1 '
alias ls='ls --color=auto'
{{ if lookPath "zoxide" -}}
alias cd="z"
{{ end -}}
{{ if lookPath "nvim" -}}
alias vim="nvim"
export EDITOR=nvim
{{ else -}}
export EDITOR=vim
{{ end -}}

if [ "$DISPLAY_SERVER" = "wayland" ]; then
    export TERMINAL="foot"
else
    export TERMINAL="urxvt"
fi

function start_gui_x11 {
    export TERMINAL="urxvt"
    exec startx
}

function start_gui_wayland {
    export TERMINAL="foot"
    exec sway --unsupported-gpu
}

function start_gui {
    # From TTY, default to wayland; pass "x11" to override
    if [ "$1" = "x11" ]; then
        start_gui_x11
    else
        start_gui_wayland
    fi
}

function vlc {
    if [ "$DISPLAY_SERVER" = "x11" ]; then
        export DISPLAY="${DISPLAY:-:0}"
    else
        export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
    fi
    /usr/bin/vlc "$@"
}


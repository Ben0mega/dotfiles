function ssh_agent_persistent {
    source ~/.ssh_agent
    if [ "$SSH_AGENT_PID" != "" ]
    then
	    if ps -p "$SSH_AGENT_PID" > /dev/null
	    then
		    if [ "ssh-agent" = "$(ps -p "$SSH_AGENT_PID" -o comm=)" ]
		    then
			    echo "Agent already running"
			    return
		    else
			    echo "pid mismatch"
	            fi
	    else
		    echo "pid not found"
	    fi
    else
	    echo "pid not defined"
    fi
    COMMANDS="$(ssh-agent -s)"
    echo "$COMMANDS" > ~/.ssh_agent
    source ~/.ssh_agent
}

function ssh_agent_persistent_and_add_key {
KEY="$1"
if [ "$KEY" == "" ]
then
	KEY="id_rsa"
fi
    ssh_agent_persistent
    ssh-add ~/.ssh/"$KEY"
}


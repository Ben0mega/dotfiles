function barrier_unstick_keys {
	if [ "$DISPLAY_SERVER" != "x11" ]; then
		echo "barrier_unstick_keys is only supported under X11"
		return 1
	fi
	xinput --query-state 5 | grep down | sed 's/\s*key\[\([0-9]\+\)\]=down/\1/g' | xargs xdotool keyup
}


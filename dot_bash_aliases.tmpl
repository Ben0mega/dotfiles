function tm() {
 	RAW_DIR="${1:-$PWD}"
	DIR="$(realpath $RAW_DIR | sed 's#/#_#g')"
	if [ "$(tmux ls | grep "$DIR"":")" != "" ]
	then
		tmux a -t "$DIR"
	else
		tmux new -s "$DIR"
	fi
}

function tma() {
 	RAW_DIR="${1:-$PWD}"
	DIR="$(realpath $RAW_DIR | sed 's#/#_#g')"
	if [ "$(tmux ls | grep "$DIR"":")" != "" ]
	then
		tmux a -t "$DIR"
	else
		TARGET="$(tmux ls -F '#S' 2>/dev/null | grep -v '^unciv$' | head -n 1)"
		if [ -n "$TARGET" ]
		then
			tmux a -t "$TARGET"
		else
			tm
		fi
	fi
}


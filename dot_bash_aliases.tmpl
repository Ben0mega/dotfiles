function compress {
	BASENAME="$(basename "$1")"
	DIRNAME="$(dirname "$1")"
	NAME="$1"
	7z a -mx=9 /tmp/"$BASENAME".7z "$NAME"
	if [ "$?" == "0" ]
	then
		mv "$NAME" /tmp/"$BASENAME"
		if [ "$?" == "0" ]
		then
			mv "/tmp/$BASENAME".7z "$DIRNAME"/"$BASENAME".7z
			if [ "$?" == "0" ]
			then
				rm -R "/tmp/$BASENAME"
			else
				echo "Failed to copy compressed file"
			fi
		else
			echo "Failed to copy original away!"
		fi
	else
		echo "Compression failed"
	fi

}

function _screensaver_disable_parse_endtime {
	if [ "$1" == "" ]
	then
		echo ""
		return 0
	fi
	ENDTIME="$(date -d "+$1" +%s 2>/dev/null)"
	if [ "$?" != "0" ]
	then
		ENDTIME="$(date -d "$1" +%s 2>/dev/null)"
		if [ "$?" != "0" ]
		then
			echo "FAIL"
			return 1
		fi
		echo "$ENDTIME"
		echo "Disabling screensaver until: $(date -d "$1")" >&2
	else
		echo "$ENDTIME"
		echo "Disabling screensaver until: $(date -d "+$1")" >&2
	fi
	return 0
}

function screensaver_disable_x11 {
	ENDTIME="$(_screensaver_disable_parse_endtime "$1")"
	if [ "$ENDTIME" = "FAIL" ]; then echo "Failed to parse date"; return; fi
	while [ 1 ]
	do
		xdotool mousemove_relative -- -1 -1
		xdotool mousemove_relative -- 1 1
		sleep 100
		if [ "$ENDTIME" != "" ]
		then
			if [ "$ENDTIME" -lt "$(date +%s)" ]
			then
				echo "Endtime reached: $(date)"
				break
			fi
		fi
	done
}

function screensaver_disable_wayland {
	ENDTIME="$(_screensaver_disable_parse_endtime "$1")"
	if [ "$ENDTIME" = "FAIL" ]; then echo "Failed to parse date"; return; fi
	while [ 1 ]
	do
		ydotool mousemove -- -1 -1
		ydotool mousemove -- 1 1
		sleep 100
		if [ "$ENDTIME" != "" ]
		then
			if [ "$ENDTIME" -lt "$(date +%s)" ]
			then
				echo "Endtime reached: $(date)"
				break
			fi
		fi
	done
}

function screensaver_disable {
	if [ "$DISPLAY_SERVER" = "x11" ]; then
		screensaver_disable_x11 "$@"
	else
		screensaver_disable_wayland "$@"
	fi
}

function pgrep_ {
	ps aux | head -n 1
	ps aux | grep "$@" | grep -v "$(echo grep "$@")"
}


function pgrep_pid {
	ps aux | grep "$@" | grep -v "$(echo grep "$@")" | awk '{ print $2 }'
}

function screensaver_kill_x11 {
	pgrep_pid "xautolock" | xargs kill
}

function screensaver_kill_wayland {
	pgrep_pid "swayidle" | xargs kill
}

function screensaver_kill {
	if [ "$DISPLAY_SERVER" = "x11" ]; then
		screensaver_kill_x11
	else
		screensaver_kill_wayland
	fi
}


function ffconcat {
	FILE="$(mktemp)"
	all_args=( "$@" )
	len="${#all_args[@]}"
	last_arg="${all_args[$len-1]}"
	non_last_args="${all_args[@]:0:$len-1}"
	echo "$len"
	echo "output:" "$last_arg"
	for ((i=0; i < "$(($len-1))"; i++))
	do
		f="${all_args[$i]}"
		FULL_F="$(realpath "$f")"
		echo "input:" "$i" "$FULL_F"
		echo file "'"${FULL_F}"'" >> "$FILE"
	done
	cat $FILE
	ffmpeg -f concat -safe 0 -i "$FILE" -c copy "$last_arg"
	rm "$FILE"
}


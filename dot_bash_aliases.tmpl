function activate_virtualenv {
	to_activate="$(find -wholename '*/bin/activate')"
	if [ "$to_activate" = "" ]
	then
		echo "Could not find a virtualenv!"
	else
		for tactivate in $to_activate
		do
			source "$tactivate"
		done
	fi
}


